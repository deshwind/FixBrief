# Environment files. The checked-in example contains no usable credentials.
config/env.*.json
!config/env.example.json
!config/env.*.example.json
.env
.env.*

# Supabase local development artifacts and function-local secrets
supabase/.branches/
supabase/.temp/
supabase/functions/node_modules/
supabase/functions/.env
supabase/functions/.env.*

# Logs and local databases
*.log
*.sqlite
*.sqlite3
